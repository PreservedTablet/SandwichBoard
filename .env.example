# ─────────────────────────────────────────────────────────────────────────────
# SandwichBoard configuration — EXAMPLE FILE, FAKE VALUES ONLY.
#
# The happy path is Infisical injection (bring your own project, docs/setup.md):
#   infisical run --env=dev -- pnpm dev
#
# Fallback: copy this file to .env (gitignored) and run `pnpm dev:local`.
# NEVER commit a real .env. NEVER put real values in this file.
# The full variable manifest lives in config/variables.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ────────────────────────────────────────────────────────────────
# Privileged application role. Any vanilla Postgres 15+ works.
DATABASE_URL=postgres://sandwichboard:changeme@localhost:5432/sandwichboard

# ── API bind (defaults shown) ───────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=3000

# ── Tenancy scope (default shown; fine for any solo deployment) ─────────────
# Every row carries this org_id (docs/plan/03 multi-tenant-ready schema).
#ORG_ID=00000000-0000-0000-0000-000000000000

# ── Storage adapter (local-fs is the $0 default) ────────────────────────────
STORAGE_DRIVER=local-fs
STORAGE_LOCAL_PATH=data/storage
# S3-compatible driver (Phase 1+): uncomment all four when STORAGE_DRIVER=s3
#S3_ENDPOINT=http://localhost:9000
#S3_BUCKET=sandwichboard
#S3_ACCESS_KEY=changeme
#S3_SECRET_KEY=changeme
# Supabase Storage driver: uncomment both when STORAGE_DRIVER=supabase-storage
#SUPABASE_URL=https://your-project.supabase.co
#SUPABASE_SERVICE_ROLE_KEY=changeme

# ── Analysis (Phase 3): read-only role for Claude sessions ──────────────────
#ANALYST_DATABASE_URL=postgres://analyst:changeme@localhost:5432/sandwichboard

# ── Internal command endpoints (dashboard "Sync now") ──────────────────────
# Guards POST /internal/*; unset means those endpoints answer 503.
# Generate a real one with: openssl rand -hex 32
#INTERNAL_API_TOKEN=changeme

# ── Ingestion (Phase 2) ─────────────────────────────────────────────────────
# Meta: system-user token, ads_read scope only (docs/decisions/0005).
#META_SYSTEM_USER_TOKEN=changeme
#META_AD_ACCOUNT_ID=act_0000000000
# Path to Meta's official Ads CLI (PyPI meta-ads); default: `meta` on PATH.
#META_ADS_CLI_BIN=meta
#GOOGLE_ADS_DEVELOPER_TOKEN=changeme
#GOOGLE_PROJECT_ID=your-gcp-project
#GOOGLE_ADS_MCP_OAUTH_CLIENT_ID=changeme
#GOOGLE_ADS_MCP_OAUTH_CLIENT_SECRET=changeme

# ── Publishing rail (Phase 5) ───────────────────────────────────────────────
#POSTIZ_BASE_URL=http://localhost:5000
#POSTIZ_API_KEY=changeme

# ── Capture endpoints (Phase 4) ─────────────────────────────────────────────
# Generate a real one with: openssl rand -hex 32
#INBOUND_CAPTURE_SECRET=changeme

# There is deliberately NO Anthropic key variable: all AI work runs in the
# operator's own Claude Code session on their own subscription (docs/plan/04).
